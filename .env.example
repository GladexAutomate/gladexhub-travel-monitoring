# THREE SEPARATE Supabase projects — do not mix them up.

# Sales Supabase (frontend — safe to expose, public anon/publishable key).
# Bookings/tickets (GDX, agent lookup). Fusioo-linked. flight_emails used to
# live here too, but that table is moving to Automate below.
VITE_SALES_SUPABASE_URL=https://your-sales-project-ref.supabase.co
VITE_SALES_SUPABASE_ANON_KEY=your-sales-anon-key-here

# Accounts Supabase (frontend — safe to expose, public anon/publishable key).
# Login/RBAC only — the employeeaccount table. Base URL only, no table path.
VITE_ACCOUNTS_SUPABASE_URL=https://your-accounts-project-ref.supabase.co
VITE_ACCOUNTS_SUPABASE_ANON_KEY=your-accounts-anon-key-here

# External employee directory (a DIFFERENT team/site's Supabase project —
# not ours to manage, table 'employee'). admin_accounts.full_name/department
# were populated from this source as a one-time copy; not queried live by
# the app. Not VITE_ prefixed — kept for a future re-sync script, not the
# browser bundle.
EXTERNAL_ACCOUNTS_SOURCE_URL=https://their-project-ref.supabase.co
EXTERNAL_ACCOUNTS_SOURCE_KEY=their-anon-or-publishable-key-here

# Fusioo — server/admin-tooling use only. VITE_ prefix means this gets
# bundled into the public frontend JS if imported from any client component;
# do not use it for runtime login/RBAC checks (see src/services/fusiooService.js).
VITE_FUSIOO_TOKEN=your-fusioo-bearer-token-here
FUSIOO_CLIENT_ID=your-fusioo-client-id-here
FUSIOO_CLIENT_SECRET=your-fusioo-client-secret-here

# Automate Supabase (frontend — safe to expose, public anon/publishable key).
# flight_emails only (parsed by google-apps-script/Code.gs). Writes come from
# Apps Script using the service_role key set in its own Script Properties —
# never put that key here.
VITE_AUTOMATE_SUPABASE_URL=https://your-automate-project-ref.supabase.co
VITE_AUTOMATE_SUPABASE_ANON_KEY=your-automate-anon-key-here
