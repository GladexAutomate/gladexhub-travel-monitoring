# Base44 app identity — used by src/api/base44Client.js so the SDK knows
# which app to talk to and where its real backend lives when this frontend
# runs outside Base44's own sandboxed hosting (local dev, Vercel).
VITE_BASE44_APP_ID=your-base44-app-id-here
VITE_BASE44_APP_BASE_URL=https://your-app-name.base44.app

# THREE SEPARATE Supabase projects — do not mix them up.

# Sales Supabase (frontend — safe to expose, public anon/publishable key).
# Bookings/tickets (GDX, agent lookup). Fusioo-linked. flight_emails used to
# live here too, but that table is moving to Automate below.
VITE_SALES_SUPABASE_URL=https://your-sales-project-ref.supabase.co
VITE_SALES_SUPABASE_ANON_KEY=your-sales-anon-key-here

# Accounts Supabase (frontend — safe to expose, public anon/publishable key).
# Login/RBAC only — the employeeaccount table. Base URL only, no table path.
VITE_ACCOUNTS_SUPABASE_URL=https://your-accounts-project-ref.supabase.co
VITE_ACCOUNTS_SUPABASE_ANON_KEY=your-accounts-anon-key-here

# External employee directory (a DIFFERENT team/site's Supabase project —
# not ours to manage). EXTERNAL_ACCOUNTS_SOURCE_KEY (publishable) only sees
# the 'employee' table (used once for full_name/department). The real live
# source is 'employeeaccount' (email/status/generated_password/employee_code)
# — that table needs the service_role key below, used by
# api/sync-employees.js on every periodic refresh. Neither is VITE_ prefixed
# — server/script use only, never the browser bundle.
EXTERNAL_ACCOUNTS_SOURCE_URL=https://their-project-ref.supabase.co
EXTERNAL_ACCOUNTS_SOURCE_KEY=their-anon-or-publishable-key-here
EXTERNAL_ACCOUNTS_SOURCE_KEY_V2=their-service-role-key-here

# service_role key for OUR Automate/Accounts Supabase project — used by
# api/sync-employees.js to write admin_accounts (bypasses RLS). Never put
# this in a VITE_ var / browser code.
AUTOMATE_SUPABASE_SERVICE_ROLE_KEY=your-automate-service-role-key-here

# Shared secret required in the Authorization: Bearer header of every call
# to api/sync-employees.js (and any future cron-triggered /api/* function) —
# stops randoms from hitting the endpoint and forcing an off-cycle sync.
CRON_SECRET=generate-a-long-random-string-here

# Fusioo — server/admin-tooling use only. VITE_ prefix means this gets
# bundled into the public frontend JS if imported from any client component;
# do not use it for runtime login/RBAC checks (see src/services/fusiooService.js).
VITE_FUSIOO_TOKEN=your-fusioo-bearer-token-here
FUSIOO_CLIENT_ID=your-fusioo-client-id-here
FUSIOO_CLIENT_SECRET=your-fusioo-client-secret-here

# GladExplore is a SEPARATE Fusioo account from the main Gladex one above —
# its own token, used by api/sync-fusioo-data.js's FUSIOO_SOURCES. Same
# "fusioo" Supabase project as VITE_FUSIOO_SUPABASE_URL below, just under
# gladexplore_-prefixed tables (see gladexplore_fusioo_sync_schema.sql).
GLADEXPLORE_FUSIOO_ACCESS_TOKEN=your-gladexplore-fusioo-access-token-here

# Automate Supabase (frontend — safe to expose, public anon/publishable key).
# flight_emails only (parsed by google-apps-script/Code.gs). Writes come from
# Apps Script using the service_role key set in its own Script Properties —
# never put that key here.
VITE_AUTOMATE_SUPABASE_URL=https://your-automate-project-ref.supabase.co
VITE_AUTOMATE_SUPABASE_ANON_KEY=your-automate-anon-key-here
